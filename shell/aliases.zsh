# --- Aliases ---
# 현대적 CLI 대체
alias ls="eza --icons --classify --group-directories-first"
alias ll="eza --icons --classify --group-directories-first -la"
alias cat="bat"
alias lg="lazygit"

# Git 단축
alias gs="git status -s"
alias gd="git diff"
alias gdc="git diff --cached"
alias gl="git log --oneline -20"
